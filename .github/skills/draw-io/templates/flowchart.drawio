    <mxCell id="e-decision-end" value="Yes" edge="1" source="decision1" target="end" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e-decision-error" value="No" edge="1" source="decision1" target="error-step" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e-error-end" edge="1" source="error-step" target="end" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="720" y="670"/>
          <mxPoint x="490" y="670"/>
        </Array>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
